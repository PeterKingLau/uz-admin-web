{
    "name": "uz-web",
    "version": "1.0.0",
    "description": "职场吧后台管理系统",
    "author": "高榜",
    "license": "MIT",
    "type": "module",
    "packageManager": "yarn@1.22.22",
    "scripts": {
        "dev": "vite --mode development",
        "build": "vite build --mode production",
        "build:prod": "vite build --mode production",
        "build:staging": "vite build --mode staging",
        "preview": "vite preview",
        "prepare": "husky",
        "typecheck": "vue-tsc --noEmit",
        "lint": "yarn run -s lint:eslint && yarn run -s lint:style",
        "lint:eslint": "eslint \"src/**/*.{js,ts,vue}\" \"vite/**/*.ts\" vite.config.ts eslint.config.js",
        "lint:eslint:fix": "eslint \"src/**/*.{js,ts,vue}\" \"vite/**/*.ts\" vite.config.ts eslint.config.js --fix",
        "lint:style": "stylelint \"src/**/*.vue\" --allow-empty-input",
        "lint:style:fix": "stylelint \"src/**/*.vue\" --allow-empty-input --fix",
        "format": "prettier --write \"**/*.{js,ts,vue,json,css,scss,md,yml,yaml}\"",
        "format:check": "prettier --check \"**/*.{js,ts,vue,json,css,scss,md,yml,yaml}\"",
        "lint:fix": "yarn run -s lint:eslint:fix && yarn run -s lint:style:fix && yarn run -s format",
        "verify": "yarn run -s typecheck && yarn run -s lint",
        "clean:deps": "node scripts/clean-deps.mjs",
        "clean": "node scripts/clean-deps.mjs && yarn install"
    },
    "engines": {
        "node": "^20.19.0 || >=22.12.0"
    },
    "dependencies": {
        "@faker-js/faker": "^10.4.0",
        "@iconify-json/material-symbols": "^1.2.50",
        "@iconify-json/simple-icons": "^1.2.59",
        "@iconify/vue": "^5.0.0",
        "@varlet/ui": "^3.16.1",
        "@vueuse/core": "^14.0.0",
        "@zeronejs/utils": "^2.2.1",
        "axios": "^1.13.2",
        "clipboard": "^2.0.11",
        "echarts": "^6.0.0",
        "element-plus": "^2.11.8",
        "file-saver": "^2.0.5",
        "fuse.js": "^7.1.0",
        "js-cookie": "^3.0.5",
        "md-editor-v3": "^6.4.1",
        "nprogress": "^0.2.0",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "pinyin-match": "^1.2.10",
        "qr-code-styling": "^1.9.2",
        "sortablejs": "^1.15.6",
        "video.js": "^8.23.4",
        "vue": "^3.5.24",
        "vue-cropper": "^1.1.4",
        "vue-draggable-plus": "^0.6.0",
        "vue-i18n": "11",
        "vue-router": "^5.0.6",
        "vue3-next-qrcode": "^4.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@iconify-json/ep": "^1.2.3",
        "@iconify-json/mdi": "^1.2.3",
        "@tailwindcss/postcss": "^4.3.0",
        "@types/file-saver": "^2.0.7",
        "@types/js-cookie": "^3.0.6",
        "@types/node": "^25.7.0",
        "@types/nprogress": "^0.2.3",
        "@types/sortablejs": "^1.15.8",
        "@typescript-eslint/parser": "^8.59.2",
        "@vitejs/plugin-vue": "^6.0.5",
        "autoprefixer": "^10.4.21",
        "esbuild": "^0.28.0",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.5.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "javascript-obfuscator": "^5.4.1",
        "postcss": "^8.4.38",
        "postcss-html": "^1.8.0",
        "prettier": "^3.6.2",
        "rimraf": "^6.1.2",
        "rollup-plugin-visualizer": "^7.0.1",
        "sass": "^1.99.0",
        "sass-embedded": "^1.99.0",
        "stylelint": "^17.11.0",
        "stylelint-config-recommended": "18.0.0",
        "stylelint-config-recommended-vue": "^1.6.1",
        "stylelint-config-standard": "^40.0.0",
        "tailwindcss": "^4.3.0",
        "terser": "^5.44.1",
        "typescript": "^6.0.3",
        "unplugin-auto-import": "^21.0.0",
        "unplugin-vue-components": "^32.0.0",
        "vite": "^8.0.0",
        "vite-plugin-checker": "^0.13.0",
        "vite-plugin-compression2": "^2.2.1",
        "vite-plugin-zip-pack": "^1.2.4",
        "vue-eslint-parser": "^10.2.0",
        "vue-tsc": "^3.1.4"
    }
}
